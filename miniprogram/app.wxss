page {
  min-height: 100vh;
  background: #101524;
  color: #f7f0dc;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: inherit;
}

button::after {
  border: 0;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 28rpx 56rpx;
}

.eyebrow {
  color: #c9a45a;
  font-size: 24rpx;
  letter-spacing: 0;
}

.title {
  margin-top: 12rpx;
  color: #fff8e7;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.15;
}

.subtitle {
  margin-top: 16rpx;
  color: rgba(247, 240, 220, 0.74);
  font-size: 28rpx;
  line-height: 1.6;
}

.section {
  margin-top: 36rpx;
}

.section-title {
  color: #fff8e7;
  font-size: 32rpx;
  font-weight: 700;
}

.muted {
  color: rgba(247, 240, 220, 0.62);
}

.panel {
  border: 1rpx solid rgba(201, 164, 90, 0.22);
  border-radius: 8rpx;
  background: rgba(255, 248, 231, 0.07);
}

.primary-button {
  display: flex;
  min-height: 88rpx;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #c9a45a;
  color: #16120b;
  font-size: 30rpx;
  font-weight: 700;
}

.ghost-button {
  display: flex;
  min-height: 76rpx;
  align-items: center;
  justify-content: center;
  border: 1rpx solid rgba(201, 164, 90, 0.36);
  border-radius: 8rpx;
  color: #f7f0dc;
  font-size: 28rpx;
}

.error-box {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 118, 118, 0.42);
  border-radius: 8rpx;
  background: rgba(255, 118, 118, 0.1);
  color: #ffd3d3;
  font-size: 26rpx;
  line-height: 1.5;
}
